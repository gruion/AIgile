# ─── Jira Credentials ────────────────────────────────────
# After Jira setup, create an API token at: http://localhost:9080
JIRA_BASE_URL=http://localhost:9080
JIRA_USERNAME=admin
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=TEAM

# ─── Service Ports ───────────────────────────────────────
API_PORT=3011
FRONTEND_PORT=3010

# ─── Database Passwords ─────────────────────────────────
JIRA_DB_PASSWORD=change_me_jira_db
HASURA_DB_PASSWORD=change_me_hasura_db
HASURA_ADMIN_SECRET=change_me_hasura_secret

# ─── Hasura ──────────────────────────────────────────────
HASURA_GRAPHQL_URL=http://localhost:9081/v1/graphql

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3011
NEXT_PUBLIC_JIRA_BASE_URL=http://localhost:9080
NEXT_PUBLIC_DEFAULT_JQL=project = TEAM ORDER BY status ASC, updated DESC

# ─── AI Provider ────────────────────────────────────────
# Options: mock, anthropic, openai, ollama, claude-code
AI_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Default JQL Query ──────────────────────────────────
JIRA_DEFAULT_JQL=project = TEAM ORDER BY status ASC, updated DESC
