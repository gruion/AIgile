# ─── Jira Credentials ────────────────────────────────────
# After Jira setup, create an API token at: http://localhost:9080
JIRA_BASE_URL=http://localhost:9080
JIRA_USERNAME=admin
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=TEAM

# ─── Service Ports ───────────────────────────────────────
API_PORT=3011
FRONTEND_PORT=3010

# ─── Database Passwords ─────────────────────────────────
JIRA_DB_PASSWORD=change_me_jira_db
HASURA_DB_PASSWORD=change_me_hasura_db
HASURA_ADMIN_SECRET=change_me_hasura_secret

# ─── Hasura ──────────────────────────────────────────────
HASURA_GRAPHQL_URL=http://localhost:9081/v1/graphql

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3011
NEXT_PUBLIC_JIRA_BASE_URL=http://localhost:9080
NEXT_PUBLIC_DEFAULT_JQL=project = TEAM ORDER BY status ASC, updated DESC

# ─── AI Provider ────────────────────────────────────────
# Options: mock, anthropic, openai, ollama, claude-code
AI_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Default JQL Query ──────────────────────────────────
JIRA_DEFAULT_JQL=project = TEAM ORDER BY status ASC, updated DESC

# ─── Epic Children JQL Template ─────────────────────────
# Custom JQL to find issues inside an epic. Use {EPIC_KEY} as placeholder.
# Leave empty for auto-detection (Epic Link / parent).
# Examples:
#   "Epic Link" = {EPIC_KEY} ORDER BY status ASC
#   parent = {EPIC_KEY} ORDER BY status ASC
#   labels = "{EPIC_KEY}" ORDER BY status ASC
#   cf[10014] = {EPIC_KEY} ORDER BY status ASC
EPIC_CHILDREN_JQL_TEMPLATE=

# ─── Browser URL (if different from API URL) ──────────
# Use this when the Jira API URL (e.g. Docker-internal) differs from
# the URL users open in their browser.
# JIRA_BROWSER_URL=http://localhost:9080

# ─── Multi-Server Configuration ───────────────────────
# JSON array of Jira server connections. Each entry needs:
#   id, name, url, username, token, projects (array of project keys)
#   browserUrl (optional — URL users see in their browser)
# JIRA_SERVERS=[{"id":"main","name":"My Jira","url":"http://localhost:9080","browserUrl":"http://localhost:9080","username":"admin","token":"your_token","projects":["TEAM","OPS"]}]

# ─── Team Definitions ────────────────────────────────
# JSON array of teams for PI planning. Each entry needs:
#   id, name, color, serverId, projectKey
#   jql (optional — custom JQL filter for the team's sprint board)
# TEAMS=[{"id":"team-alpha","name":"Team Alpha","color":"#3b82f6","serverId":"main","projectKey":"TEAM","jql":""}]

# ─── Program Board ────────────────────────────────────
# The project key and server used for the cross-team program board.
# PROGRAM_PROJECT=PROG
# PROGRAM_SERVER_ID=main

# ─── PI (Program Increment) Configuration ─────────────
# PI_NAME=PI 2025.1
# PI_START_DATE=2025-01-15
# PI_END_DATE=2025-04-15
# PI_SPRINT_COUNT=5
# PI_SPRINT_DURATION=14
