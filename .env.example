# ═══════════════════════════════════════════════════════════
# AIgileCoach Configuration
# ═══════════════════════════════════════════════════════════
#
# The app launches without any .env file. All Jira connection
# settings (servers, teams, credentials) are configured from
# the Settings page in the frontend and persisted to config.json.
#
# This file is only needed to override ports or provide env-level
# defaults that take effect before the first Settings save.
# ═══════════════════════════════════════════════════════════

# ─── Service Ports ───────────────────────────────────────
API_PORT=3011
FRONTEND_PORT=3010

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3011

# ─── Database Passwords (only needed with local Jira) ────
JIRA_DB_PASSWORD=change_me_jira_db

# ═══════════════════════════════════════════════════════════
# OPTIONAL: Pre-configure via env vars (overridden by Settings)
# ═══════════════════════════════════════════════════════════

# ─── Jira Credentials (fallback if no config.json) ──────
# JIRA_BASE_URL=http://localhost:9080
# JIRA_USERNAME=admin
# JIRA_API_TOKEN=your_token_here
# JIRA_PROJECT_KEY=TEAM

# ─── AI Provider ────────────────────────────────────────
# Options: mock, anthropic, openai, ollama, claude-code
# AI_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Default JQL Query ──────────────────────────────────
# JIRA_DEFAULT_JQL=project = TEAM ORDER BY status ASC, updated DESC

# ─── Epic Children JQL Template ─────────────────────────
# Custom JQL to find issues inside an epic. Use {EPIC_KEY} as placeholder.
# EPIC_CHILDREN_JQL_TEMPLATE=

# ─── TLS / SSL ────────────────────────────────────────
# Skip TLS certificate verification (self-signed certs, corporate proxies)
NODE_TLS_REJECT_UNAUTHORIZED=0

# ─── Browser URL (if different from API URL) ──────────
# JIRA_BROWSER_URL=http://localhost:9080

# ─── Multi-Server Configuration (JSON) ──────────────────
# JIRA_SERVERS=[{"id":"main","name":"My Jira","url":"http://localhost:9080","username":"admin","token":"your_token","projects":["TEAM"]}]

# ─── Team Definitions (JSON) ────────────────────────────
# TEAMS=[{"id":"team-alpha","name":"Team Alpha","color":"#3b82f6","serverId":"main","projectKey":"TEAM"}]

# ─── Program Board ──────────────────────────────────────
# PROGRAM_PROJECT=PROG
# PROGRAM_SERVER_ID=main

# ─── PI (Program Increment) Configuration ───────────────
# PI_NAME=PI 2025.1
# PI_START_DATE=2025-01-15
# PI_END_DATE=2025-04-15
# PI_SPRINT_COUNT=5
# PI_SPRINT_DURATION=14
